    _selectedDay = DateTime.now();
    _loadSettingsAndRole();
  }

  Future<void> _loadSettingsAndRole() async {
    User? user = FirebaseAuth.instance.currentUser;
    if (user != null) {
      var snapshot = await FirebaseFirestore.instance
          .collection('users')
          .where('email', isEqualTo: user.email)
          .limit(1)
          .get();
      if (snapshot.docs.isNotEmpty && mounted) {
        setState(() => _currentUserName = snapshot.docs.first['name']);
      }
    }
  }

  String _getDateKey(DateTime date) => "${date.year}-${date.month}-${date.day}";

  Future<void> _assignChore(
    String choreTitle,
    List<String> defaultSteps,
    List<Map<String, dynamic>> assignedUsers,
  ) async {
    if (_selectedDay == null) return;
    List<Map<String, dynamic>> substepsData = defaultSteps
        .map((s) => {'title': s, 'isDone': false})
        .toList();

    WriteBatch batch = FirebaseFirestore.instance.batch();
    for (var user in assignedUsers) {
      var docRef = FirebaseFirestore.instance.collection('chores').doc();
      batch.set(docRef, {
        'date': _getDateKey(_selectedDay!),
        'chore': choreTitle,
        'who': user['name'],
        'whoColor': user['color'],
        'isDone': false,
        'substeps': substepsData,
      });
    }
    await batch.commit();
  }

  Future<void> _toggleDone(String docId, bool newValue) async {
    await FirebaseFirestore.instance.collection('chores').doc(docId).update({
      'isDone': newValue,
    });
  }

  Future<void> _deleteChore(String docId) async {
    await FirebaseFirestore.instance.collection('chores').doc(docId).delete();
  }

  Future<void> _addSubStep(String docId) async {
    if (_subStepController.text.isEmpty) return;
    String text = _subStepController.text;
    _subStepController.clear();

    var doc = await FirebaseFirestore.instance
        .collection('chores')
        .doc(docId)
        .get();
    if (doc.exists) {
      List currentSteps = doc.data()?['substeps'] ?? [];
      currentSteps.add({'title': text, 'isDone': false});
      await FirebaseFirestore.instance.collection('chores').doc(docId).update({
        'substeps': currentSteps,
      });
    }
  }

  Future<void> _toggleSubStep(String docId, int index, bool currentVal) async {
    var doc = await FirebaseFirestore.instance
        .collection('chores')
        .doc(docId)
        .get();
    if (doc.exists) {
      List currentSteps = List.from(doc.data()?['substeps'] ?? []);
      currentSteps[index]['isDone'] = !currentVal;
      bool allDone = currentSteps.every((s) => s['isDone'] == true);
      await FirebaseFirestore.instance.collection('chores').doc(docId).update({
        'substeps': currentSteps,
        if (allDone) 'isDone': true,
      });
    }
  }

  Future<void> _deleteSubStep(String docId, int index) async {
    var doc = await FirebaseFirestore.instance
        .collection('chores')
        .doc(docId)
        .get();
    if (doc.exists) {
      List currentSteps = List.from(doc.data()?['substeps'] ?? []);
      currentSteps.removeAt(index);
      await FirebaseFirestore.instance.collection('chores').doc(docId).update({
        'substeps': currentSteps,
      });
    }
  }

  void _quickSwapPerson(String docId, String choreName) {
    List<Map<String, dynamic>> selectedUsers = [];
    showDialog(
      context: context,
      builder: (context) {
        return StatefulBuilder(
          builder: (context, setStateDialog) {
            return AlertDialog(
              backgroundColor: Colors.white,
              title: Text(
                "Vem ska ta över '$choreName'?",
                style: const TextStyle(fontSize: 18),
              ),
              content: SizedBox(
                height: 130,
                width: double.maxFinite,
                child: StreamBuilder<QuerySnapshot>(
                  stream: FirebaseFirestore.instance
                      .collection('users')
                      .snapshots(),
                  builder: (context, snapshot) {
                    if (!snapshot.hasData)
                      return const Center(child: CircularProgressIndicator());
                    var users = snapshot.data!.docs;
                    return ListView.builder(
                      scrollDirection: Axis.horizontal,
                      itemCount: users.length,
                      itemBuilder: (context, index) {
                        var uData = users[index].data() as Map<String, dynamic>;
                        String name = uData['name'] ?? "?";
                        String colorHex = uData['color'] ?? 'ff2196f3';
                        Color uColor = Color(int.parse(colorHex, radix: 16));
                        bool isSelected = selectedUsers.any(
                          (u) => u['name'] == name,
                        );
                        return Padding(
                          padding: const EdgeInsets.symmetric(horizontal: 10),
                          child: GestureDetector(
                            onTap: () {
                              setStateDialog(() {
                                if (isSelected) {
                                  selectedUsers.removeWhere(
                                    (u) => u['name'] == name,
                                  );
                                } else {
                                  selectedUsers.add({
                                    'name': name,
                                    'color': colorHex,
                                  });
                                }
                              });
                            },
                            child: Column(
                              mainAxisAlignment: MainAxisAlignment.center,
                              children: [
                                Stack(
                                  alignment: Alignment.center,
                                  children: [
                                    CircleAvatar(
                                      radius: 30,
                                      backgroundColor: uColor,
                                      child: Text(
                                        name.isNotEmpty
                                            ? name[0].toUpperCase()
                                            : "?",
                                        style: const TextStyle(
                                          color: Colors.white,
                                          fontWeight: FontWeight.bold,
                                          fontSize: 20,
                                        ),
                                      ),
                                    ),
                                    if (isSelected)
                                      const Icon(
                                        Icons.check_circle,
                                        color: Colors.green,
                                        size: 24,
                                      ),
                                  ],
                                ),
                                const SizedBox(height: 5),
                                Text(
                                  name,
                                  style: TextStyle(
                                    fontSize: 12,
                                    fontWeight: isSelected
                                        ? FontWeight.bold
                                        : FontWeight.normal,
                                  ),
                                ),
                              ],
                            ),
                          ),
                        );
                      },
                    );
                  },
                ),
              ),
              actions: [
                TextButton(
                  onPressed: () => Navigator.pop(context),
                  child: const Text("Avbryt"),
                ),
                ElevatedButton(
                  onPressed: selectedUsers.isEmpty
                      ? null
                      : () {
                          String newNameStr = selectedUsers
                              .map((u) => u['name'])
                              .join(' & ');
                          String newColorStr = selectedUsers.first['color'];
                          FirebaseFirestore.instance
                              .collection('chores')
                              .doc(docId)
                              .update({
                                'who': newNameStr,
                                'whoColor': newColorStr,
                              });
                          Navigator.pop(context);
                        },
                  child: const Text("Spara"),
                ),
              ],
            );
          },
        );
      },
    );
  }

  void _showAssignDialog(String choreTitle, List<dynamic> rawSteps) {
    List<String> steps = rawSteps.map((e) => e.toString()).toList();
    List<Map<String, dynamic>> selectedUsers = [];
    showDialog(
      context: context,
      builder: (context) {
        return StatefulBuilder(
          builder: (context, setStateDialog) {
            return AlertDialog(
              title: Text("Vem ska $choreTitle?"),
              backgroundColor: Colors.white,
              content: SizedBox(
                width: 300,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    const Text(
                      "Välj person(er):",
                      style: TextStyle(fontWeight: FontWeight.bold),
                    ),
                    Flexible(
                      child: StreamBuilder<QuerySnapshot>(
                        stream: FirebaseFirestore.instance
                            .collection('users')
                            .snapshots(),
                        builder: (context, snapshot) {
                          if (!snapshot.hasData) return const SizedBox();
                          return ListView.builder(
                            shrinkWrap: true,
                            itemCount: snapshot.data!.docs.length,
                            itemBuilder: (context, index) {
                              var data =
                                  snapshot.data!.docs[index].data() as Map;
                              return CheckboxListTile(
                                title: Text(data['name']),
                                value: selectedUsers.any(
                                  (u) => u['name'] == data['name'],
                                ),
                                onChanged: (val) => setStateDialog(
                                  () => val!
                                      ? selectedUsers.add({
                                          'name': data['name'],
                                          'color': data['color'],
                                        })
                                      : selectedUsers.removeWhere(
                                          (u) => u['name'] == data['name'],
                                        ),
                                ),
                              );
                            },
                          );
                        },
                      ),
                    ),
                  ],
                ),
              ),
              actions: [
                ElevatedButton(
                  onPressed: () {
                    _assignChore(choreTitle, steps, selectedUsers);
                    Navigator.pop(context);
                  },
                  child: const Text("Tilldela"),
                ),
              ],
            );
          },
        );
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    Color textColor = AppTheme.getTextColor();
    Color cardColor = AppTheme.getCardColor();

    return Scaffold(
      extendBodyBehindAppBar: true,
      appBar: AppBar(
        title: Text(
          "Sysslor",
