                                                  onSubmitted: (_) =>
                                                      _addSubStep(
                                                        docs[index].id,
                                                      ),
                                                ),
                                              ),
                                              const SizedBox(width: 10),
                                              Container(
                                                decoration: const BoxDecoration(
                                                  color: Colors.blueAccent,
                                                  shape: BoxShape.circle,
                                                ),
                                                child: IconButton(
                                                  icon: const Icon(
                                                    Icons.add,
                                                    color: Colors.white,
                                                  ),
                                                  onPressed: () => _addSubStep(
                                                    docs[index].id,
                                                  ),
                                                ),
                                              ),
                                            ],
                                          ),
                                          const SizedBox(height: 20),
                                          const Divider(),
                                          Center(
                                            child: TextButton.icon(
                                              onPressed: () =>
                                                  _deleteChore(docs[index].id),
                                              icon: const Icon(
                                                Icons.delete_forever,
                                                color: Colors.red,
                                              ),
                                              label: const Text(
                                                "Ta bort hela uppgiften",
                                                style: TextStyle(
                                                  color: Colors.red,
                                                  fontWeight: FontWeight.bold,
                                                ),
                                              ),
                                            ),
                                          ),
                                        ],
                                      ),
                                    ),
                                ],
                              ),
                            );
                          },
                        ),
                        Container(
                          padding: const EdgeInsets.all(20),
                          margin: const EdgeInsets.all(20),
                          decoration: BoxDecoration(
                            color: cardColor,
                            borderRadius: BorderRadius.circular(20),
                          ),
                          child: StreamBuilder<QuerySnapshot>(
                            stream: FirebaseFirestore.instance
                                .collection('chore_templates')
                                .snapshots(),
                            builder: (context, tmplSnapshot) {
                              if (!tmplSnapshot.hasData)
                                return const Text("Laddar mallar...");
                              var templates = tmplSnapshot.data!.docs;
                              if (templates.isEmpty)
                                return const Text(
                                  "Inga mallar än. Gå till Inställningar -> Hantera Mallar.",
                                );

                              return Wrap(
                                spacing: 8,
                                children: templates.map((doc) {
                                  var data = doc.data() as Map;
                                  return ActionChip(
                                    label: Text(data['title']),
                                    backgroundColor: Colors.white.withOpacity(
                                      0.9,
                                    ),
                                    onPressed: () => _showAssignDialog(
                                      data['title'],
                                      data['steps'] ?? [],
                                    ),
                                  );
                                }).toList(),
                              );
                            },
                          ),
                        ),
                        const SizedBox(height: 50),
                      ],
                    );
                  },
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }
}
