                    ),
                  ),
                ),
                const SizedBox(height: 20),
                StreamBuilder<QuerySnapshot>(
                  stream: FirebaseFirestore.instance
                      .collection('chores')
                      .where('date', isEqualTo: _getDateKey(_selectedDay!))
