                    // SWIPE FIX
                    availableGestures: AvailableGestures.none,

                    selectedDayPredicate: (day) => isSameDay(_selectedDay, day),
                    onDaySelected: (s, f) => setState(() {
                      _selectedDay = s;
                      _focusedDay = f;
                    }),
