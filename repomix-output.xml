import 'package:flutter/material.dart';
import 'dart:async';

// En global tjänst som hela appen kan lyssna på
class TimerService {
  static final TimerService _instance = TimerService._internal();
  factory TimerService() => _instance;
  TimerService._internal();

  // Variabler som appen kan lyssna på
  final ValueNotifier<int> remainingSeconds = ValueNotifier(15 * 60);
  final ValueNotifier<int> totalSeconds = ValueNotifier(15 * 60);
  final ValueNotifier<bool> isRunning = ValueNotifier(false);

  Timer? _timer;

  // Starta timern
  void startTimer() {
    if (remainingSeconds.value <= 0) {
      // Om den är noll, återställ först
      remainingSeconds.value = totalSeconds.value;
    }

    isRunning.value = true;
    _timer?.cancel();

    _timer = Timer.periodic(const Duration(seconds: 1), (timer) {
      if (remainingSeconds.value > 0) {
        remainingSeconds.value--;
      } else {
        stopTimer();
        // Här skulle man kunna spela upp ett ljud i framtiden!
      }
    });
  }

  // Pausa timern
  void stopTimer() {
    _timer?.cancel();
    isRunning.value = false;
  }

  // Återställ timern
  void resetTimer() {
    stopTimer();
    remainingSeconds.value = totalSeconds.value;
  }

  // Sätt ny tid (bara om den inte körs)
  void setDuration(double minutes) {
    if (!isRunning.value) {
      totalSeconds.value = (minutes * 60).round();
      remainingSeconds.value = totalSeconds.value;
    }
  }
}
