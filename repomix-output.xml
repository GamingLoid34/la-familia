                backgroundColor: Colors.blueAccent,
              ),
              child: const Text(
                "SPARA",
                style: TextStyle(
                  color: Colors.white,
                  fontWeight: FontWeight.bold,
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }
