<file path="lib/app_theme.dart">
import 'package:flutter/material.dart';

class AppTheme {
  // --- TEXTFÄRGER ---
  // Vi kör nästan svart text för att det ska synas bra mot de nya starkare färgerna
  static Color getTextColor() => const Color(0xFF1A1A1A); 
  static Color getSubTextColor() => const Color(0xFF4A4A4A);

  // --- RUTFÄRG ---
  // Vit med 50% genomskinlighet för att bakgrunden ska lysa igenom
  static Color getCardColor() => Colors.white.withOpacity(0.5);

  // --- DAGFÄRGER (Matchar din NPF-bild) ---
  static Color getNpfDayColor(int weekday) {
    switch (weekday) {
      case 1: return const Color(0xFF81C784); // Måndag: GRÖN (Tydlig)
      case 2: return const Color(0xFF64B5F6); // Tisdag: BLÅ (Himmelsblå)
      case 3: return const Color(0xFFFFFFFF); // Onsdag: VIT
      case 4: return const Color(0xFFA1887F); // Torsdag: BRUN (Tydlig ljusbrun)
      case 5: return const Color(0xFFFFF176); // Fredag: GUL (Solgul)
      case 6: return const Color(0xFFF06292); // Lördag: ROSA
      case 7: return const Color(0xFFE57373); // Söndag: RÖD
      default: return Colors.white;
    }
  }

  // Textfärg inne i de små kalenderbollarna
  static Color getNpfTextColor(int weekday) {
    return const Color(0xFF1A1A1A);
  }

  // --- BAKGRUND (Gradient) ---
  static BoxDecoration getBackground() {
    final int weekday = DateTime.now().weekday;
    Color baseColor = getNpfDayColor(weekday);
    
    return BoxDecoration(
      gradient: LinearGradient(
        begin: Alignment.topCenter,
        end: Alignment.bottomCenter,
        colors: [
          baseColor, // Stark färg upptill
          Colors.white, // Tona ut mot vitt nertill för en fräsch look
        ],
      ),
    );
  }

  // --- IKONER ---
  static IconData getEventIcon(String title, String type) {
    String t = title.toLowerCase();
    if (t.contains('läkare') || t.contains('tand') || t.contains('sjukhus')) return Icons.medical_services_rounded;
    if (t.contains('skola') || t.contains('läxa') || t.contains('prov')) return Icons.school_rounded;
    if (t.contains('fotboll') || t.contains('träning') || t.contains('dans')) return Icons.sports_soccer_rounded;
    if (t.contains('städa') || t.contains('disk') || t.contains('plocka')) return Icons.cleaning_services_rounded;
    if (type == 'food') return Icons.restaurant_rounded;
    if (type == 'work') return Icons.work_rounded;
    return Icons.event_note_rounded;
  }
}
</file>

