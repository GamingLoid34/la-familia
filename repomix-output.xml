                                                        ),
                                                  ),
                                                  IconButton(
                                                    icon: Icon(
                                                      Icons.close,
                                                      size: 18,
                                                      color: Colors.red
                                                          .withOpacity(0.5),
                                                    ),
                                                    onPressed: () =>
                                                        _deleteSubStep(
                                                          docs[index].id,
                                                          idx,
                                                        ),
                                                  ),
                                                ],
                                              ),
                                            );
                                          }).toList(),
                                          const SizedBox(height: 10),
                                          Row(
                                            children: [
                                              Expanded(
                                                child: TextField(
                                                  controller:
                                                      _subStepController,
                                                  style: TextStyle(
