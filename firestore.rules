rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hjälpfunktion för att hämta inloggad användares familyId
    function getUserFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    // Hjälpfunktion för inloggningskrav
    function isAuth() {
      return request.auth != null;
    }

    // 1. ANVÄNDARE (users)
    match /users/{userId} {
      // Man får läsa och skriva sin egen profil (även om man saknar familyId än)
      allow read, write: if isAuth() && request.auth.uid == userId;
      
      // Man får läsa andra användare i SAMMA familj
      allow read: if isAuth() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && resource.data.familyId == getUserFamilyId();
    }

    // 2. FAMILJER (families)
    match /families/{familyId} {
      // Tillåt alla inloggade att läsa (behövs för att söka på inbjudningskod)
      allow read: if isAuth();
      // Alla inloggade får skapa en ny familj
      allow create: if isAuth();
      // Bara medlemmar i familjen får uppdatera familjedokumentet
      allow update: if isAuth() && familyId == getUserFamilyId();
    }

    // 3. KÄRNDATA (Låst till familjens ID)
    // Här kräver vi nu att man FAKTISKT har ett familyId för att få prata med dessa samlingar
    
    match /chores/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }
    
    match /planner_events/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    match /shopping_items/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }
    
    match /calendar_imports/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }
    
    match /chore_templates/{docId} {
      allow read: if isAuth() && (resource.data.familyId == getUserFamilyId() || resource.data.familyId == "");
      allow update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    match /activity_templates/{docId} {
      allow read: if isAuth() && (resource.data.familyId == getUserFamilyId() || resource.data.familyId == "");
      allow update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    match /screen_rules/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    match /work_shifts/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    match /countdowns/{docId} {
      allow read, update, delete: if isAuth() && resource.data.familyId == getUserFamilyId();
      allow create: if isAuth() && request.resource.data.familyId == getUserFamilyId();
    }

    // Subcollection för points_history under users
    match /users/{userId}/points_history/{docId} {
      allow read: if isAuth() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(userId)).data.familyId == getUserFamilyId());
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Stäng ute allt annat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}